{
  "name": "milkmaster",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --external:express --external:firebase-admin --external:@google/genai --external:dotenv --outfile=server.cjs",
    "start": "node server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js server.cjs server.js.map server.cjs.map",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor-firebase/app-check": "^8.3.0",
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@google/genai": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.14.4",
    "@vitejs/plugin-react": "^5.0.4",
    "dayjs": "^1.11.21",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "google-auth-library": "^10.7.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hot-toast": "^2.6.0",
    "uplot": "^1.6.32",
    "uplot-react": "^1.2.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
